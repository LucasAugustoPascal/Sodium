{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SodiumMC",
  "version": "0.1.0",
  "identifier": "fr.ezrogue.sodiumlauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SodiumMC V1.0",
        "width": 900,
        "height": 600,
        "resizable": false,
        "devtools": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "launcher/launcher.js",
      "resources/mods/*"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}